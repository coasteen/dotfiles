#!/bin/sh
# Credits to Swindles McCoop
# Coast's configuration of Firemenu
# ## Chromemenu
set -e
DMENU_CMD="dmenu -i -fn JetBrainsMonoNerdFont:size=9 -nb #454545 -nf #eeeeee -sb #666666 -sf #eeeeee"
CHOICES="URL
Google
YouTube
Spotify
Discord
Git.gay
Github
DeepSeek
ChatGPT
4chan
Proton Inbox
Proton Drive
Google Inbox
Ente Auth"

CHOICE=$(printf "$CHOICES" | $DMENU_CMD -p "Chromemenu ")
SWALLOW=

case $CHOICE in
    "URL") printf '' | $DMENU_CMD -p 'Enter URL(s):' | xargs $SWALLOW chromium > /dev/null ;;
	"Discord") $SWALLOW chromium https://discord.com/app/ > /dev/null ;;
	"Spotify") $SWALLOW chromium https://open.spotify.com/ > /dev/null ;;
	"DeepSeek") $SWALLOW chromium https://chat.deepseek.com/ > /dev/null ;;
	"ChatGPT") $SWALLOW chromium https://chatgpt.com/ > /dev/null ;;
	#"Github") $SWALLOW chromium https://github.com/ > /dev/null ;;
	"Github") printf '' | $DMENU_CMD -p 'Repository:' | sed 's|^|https://github.com/|' | sed 's/ /%20/g' | xargs $SWALLOW chromium > /dev/null ;;
	"Git.gay") printf '' | $DMENU_CMD -p 'Repository:' | sed 's|^|https://git.gay/|' | sed 's/ /%20/g' | xargs $SWALLOW chromium > /dev/null ;;
	#"Git.gay") $SWALLOW chromium https://git.gay/ > /dev/null ;;
	"Google") printf '' | $DMENU_CMD -p 'Search:' | sed 's|^|https://google.com/search?q=|' | sed 's/ /%20/g' | xargs $SWALLOW chromium > /dev/null ;;
	"Link") printf '' | $DMENU_CMD -p 'Enter URL(s):' | xargs $SWALLOW chromium > /dev/null ;;
	"YouTube") printf '' | $DMENU_CMD -p 'Search:' | sed 's|^|https://youtube.com/results?search_query=|' | sed 's/ /%20/g' | xargs $SWALLOW chromium > /dev/null ;;
    "4chan") printf '3\na\naco\nadv\nan\nb\nbant\nbiz\nc\ncgl\nck\ncm\nco\nd\ndiy\ne\nf\nfa\nfit\ng\ngd\ngif\nh\nhc\nhis\nhm\nhr\ni\nic\nint\njp\nk\nlgbt\nlit\nm\nmlp\nmu\nn\nnews\no\nout\np\npo\npol\npw\nqa\nqst\nr\nr9k\ns\ns4s\nsci\nsoc\nsp\nt\ntg\ntoy\ntrv\ntv\nu\nv\nvg\nvip\nvm\nvmg\nvp\nvr\nvrpg\nvst\nvt\nw\nwg\nwsg\nwsr\nx\nxs\ny' | $DMENU_CMD -p 'Board letter:' | sed 's|^|https://4chan.org/|' | xargs $SWALLOW chromium > /dev/null ;;
    "Proton Inbox") printf '' | $SWALLOW chromium https://mail.proton.me/u/0/inbox > /dev/null ;;
    "Proton Drive") printf '' | $SWALLOW chromium https://drive.proton.me/ > /dev/null ;;
    "Google Inbox") printf '' | $SWALLOW chromium https://mail.google.com/mail/u/0/ ;;
    "Ente Auth") printf '' | $SWALLOW chromium https://auth.ente.io/auth ;; 
esac
